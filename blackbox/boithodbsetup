#!/bin/sh

export BOITHOHOME=/home/boitho/boithoTools

# Wait for the database server to accept connections before seeding it. On
# systemd platforms there is no ordering between this service and the native
# mariadb/mysqld unit, so without this wait the database could be seeded before
# the server is up (leaving boithobb uncreated). Harmless where the DB is
# already running.
i=0
while ! mysqladmin ping --silent 2>/dev/null; do
	i=$((i + 1))
	if [ $i -gt 60 ]; then
		echo "boithodbsetup: timed out waiting for the database server" >&2
		break
	fi
	sleep 1
done

# Seed only once. The web admin's activeUsers table is created by the migrations
# below, so its presence means the DB is already set up — skip re-seeding, which
# would otherwise spew harmless-but-noisy duplicate-key errors on every restart.
if mysql -uboitho -pG7J7v5L5Y7 boithobb -e 'SELECT 1 FROM activeUsers LIMIT 1' >/dev/null 2>&1; then
	echo "boithodbsetup: database already seeded, skipping"
else
	# Create the database and user.
	mysql < $BOITHOHOME/blackbox/creatuser.sql
	# Load the base schema, then the current schema migrations (which add the
	# newer tables the web admin needs, e.g. activeUsers/system/shareResults).
	# Both dumps predate MariaDB 5.5 and use the removed `TYPE=<engine>` clause,
	# so rewrite it to `ENGINE=` on the fly. --force skips statements that are
	# already applied instead of aborting the load.
	sed 's/TYPE=MyISAM/ENGINE=MyISAM/g' $BOITHOHOME/blackbox/boithobb.sql | mysql --force -uboitho -pG7J7v5L5Y7 boithobb
	sed 's/TYPE=MyISAM/ENGINE=MyISAM/g' $BOITHOHOME/sql/update-cur.sql     | mysql --force -uboitho -pG7J7v5L5Y7 boithobb
fi

